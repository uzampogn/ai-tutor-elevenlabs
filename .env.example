# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs — powers TTS (/api/speak) AND STT token minting (/api/stt-token).
# Without it: answers are text-only and voice input falls back to the
# browser's Web Speech API (Chrome/Edge only).
ELEVENLABS_API_KEY=...

# Voice ID — default is "Rachel". Find others at https://api.elevenlabs.io/v1/voices
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Supabase Postgres — TRANSACTION POOLER connection string (host ...pooler.supabase.com, port 6543).
# Use the transaction pooler, NOT the direct 5432 connection (IPv6-only, unreachable from Vercel).
# Set via the Supabase Vercel integration or by hand. Required in prod; optional locally
# (without it the app live-scrapes every request).
# The Supabase Vercel integration provisions POSTGRES_URL automatically; the app reads either
# (DATABASE_URL || POSTGRES_URL), so you don't need to add a DATABASE_URL alias by hand.
DATABASE_URL=postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require

# Voyage AI embeddings (RAG retrieval — spec/rag-retrieval-citations).
# Get a key at https://dash.voyageai.com. OPTIONAL: unset ⇒ retrieval is off and
# chat behaves exactly as before (summaries-only grounding, title-match chips).
VOYAGE_API_KEY=

# Embedding model override (default voyage-3.5-lite, 1024 dims). Changing it
# re-embeds all articles on the next cron.
# EMBEDDING_MODEL=voyage-3.5-lite
